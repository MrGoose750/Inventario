# =========================================================================
#                 INVENTARIO HOGAR - CONFIGURACIÓN DE ENTORNO
# =========================================================================

# --- 1. GEMINI AI API REQUISITES ---
# Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# --- 2. DEPLOYMENT CORE ---
# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- 3. BACKEND FASTAPI CONFIGURATIONS ---
# DATABASE_URL: Ubicación y controlador de la base de datos física SQLite.
DATABASE_URL="sqlite:///inventario_hogar.db"

# FASTAPI_PORT: Puerto interno utilizado por Uvicorn para servir FastAPI.
FASTAPI_PORT=8000

# DEBUG_MODE: Activa el reloader automático y outputs verbosos del backend.
DEBUG_MODE="false"

# ALLOWED_CORS_ORIGINS: Servidores del frontend autorizados para consumir servicios API.
# Utilizar "*" para sandbox, o dominios específicos en producción (ej: https://inventario.tuempresa.com)
ALLOWED_CORS_ORIGINS="*"
